<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avayomi="https://github.com/arudenkun/avayomi">
    <Design.PreviewWith>
        <Border
            Width="300"
            Height="300"
            Padding="80"
            Background="#1a1a1a">
            <avayomi:FloatingActionButton
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                TriggerContent="+">
                <Button Content="A" />
                <Button Content="B" />
            </avayomi:FloatingActionButton>
        </Border>
    </Design.PreviewWith>

    <Style Selector="avayomi|FloatingActionButton">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!--  Base alignment for buttons: Bottom-Right by default (Vertical/Flower)  -->
    <Style Selector="avayomi|FloatingActionButton &gt; Button">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Margin" Value="16" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform" Value="scale(0.5)" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition
                    Easing="CubicEaseOut"
                    Property="Opacity"
                    Duration="0:0:0.15" />
                <TransformOperationsTransition
                    Easing="CubicEaseOut"
                    Property="RenderTransform"
                    Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>

    <!--  Specific alignment for Horizontal and Flower: Bottom-Left  -->
    <Style Selector="avayomi|FloatingActionButton[Layout=Horizontal] &gt; Button, avayomi|FloatingActionButton[Layout=Flower] &gt; Button">
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <!--  Trigger button: always visible  -->
    <Style Selector="avayomi|FloatingActionButton &gt; Button.fab-trigger">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="RenderTransform" Value="scale(1)" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>

    <!--  VERTICAL LAYOUT: When open, stack buttons upward from trigger  -->
    <Style Selector="avayomi|FloatingActionButton[Layout=Vertical][IsOpen=True] &gt; Button">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <Style Selector="avayomi|FloatingActionButton[Layout=Vertical][IsOpen=True] &gt; Button:nth-last-child(2)">
        <Setter Property="RenderTransform" Value="translateY(-48px)" />
    </Style>
    <Style Selector="avayomi|FloatingActionButton[Layout=Vertical][IsOpen=True] &gt; Button:nth-last-child(3)">
        <Setter Property="RenderTransform" Value="translateY(-96px)" />
    </Style>
    <Style Selector="avayomi|FloatingActionButton[Layout=Vertical][IsOpen=True] &gt; Button:nth-last-child(4)">
        <Setter Property="RenderTransform" Value="translateY(-144px)" />
    </Style>
    <Style Selector="avayomi|FloatingActionButton[Layout=Vertical][IsOpen=True] &gt; Button:nth-last-child(5)">
        <Setter Property="RenderTransform" Value="translateY(-192px)" />
    </Style>

    <!--  HORIZONTAL LAYOUT: When open, stack buttons rightward from trigger  -->
    <Style Selector="avayomi|FloatingActionButton[Layout=Horizontal]">
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="avayomi|FloatingActionButton[Layout=Horizontal] &gt; Button">
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="avayomi|FloatingActionButton[Layout=Horizontal][IsOpen=True] &gt; Button">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <Style Selector="avayomi|FloatingActionButton[Layout=Horizontal][IsOpen=True] &gt; Button:nth-last-child(2)">
        <Setter Property="RenderTransform" Value="translateX(144px)" />
    </Style>
    <Style Selector="avayomi|FloatingActionButton[Layout=Horizontal][IsOpen=True] &gt; Button:nth-last-child(3)">
        <Setter Property="RenderTransform" Value="translateX(96px)" />
    </Style>
    <Style Selector="avayomi|FloatingActionButton[Layout=Horizontal][IsOpen=True] &gt; Button:nth-last-child(4)">
        <Setter Property="RenderTransform" Value="translateX(48px)" />
    </Style>
    <Style Selector="avayomi|FloatingActionButton[Layout=Horizontal][IsOpen=True] &gt; Button:nth-last-child(5)">
        <Setter Property="RenderTransform" Value="translateX(192px)" />
    </Style>
</Styles>