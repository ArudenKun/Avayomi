<UserControl
    x:Class="Avayomi.Views.Pages.AnimePageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avayomi="https://github.com/arudenkun/avayomi"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="avayomi:AnimePageViewModel"
    mc:Ignorable="d">
    <Grid RowDefinitions="Auto, *">
        <StackPanel
            Grid.Row="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <!--  ReSharper disable Xaml.InvalidType  -->
            <TextBox
                MinWidth="100"
                Text="{Binding Search}" />
            <Button
                Command="{Binding SubmitCommand}"
                Content="Submit"
                IsEnabled="{Binding !IsBusy}" />
            <Button
                Command="{Binding SubmitCancelCommand}"
                Content="Cancel"
                IsEnabled="{Binding IsBusy}" />
            <ComboBox
                ItemsSource="{Binding AnimeProviders}"
                PlaceholderText="Providers"
                SelectedItem="{Binding AnimeProvider}" />
            <!--  ReSharper restore Xaml.InvalidType  -->

        </StackPanel>
        <!--  ReSharper disable Xaml.InvalidType  -->
        <avayomi:BusyArea
            Grid.Row="1"
            BusyText="{Binding BusyText}"
            IsBusy="{Binding IsBusy}">
            <!--  ReSharper restore Xaml.InvalidType  -->
            <ScrollViewer
                Name="PopularThisSeasonScroller"
                Margin="25,0,0,0">
                <ItemsRepeater
                    ItemsSource="{Binding Animes}"
                    ScrollViewer.IsScrollChainingEnabled="True">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            ItemsStretch="Fill"
                            MinColumnSpacing="15"
                            MinRowSpacing="5"
                            Orientation="Horizontal" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </avayomi:BusyArea>
        <!--  ReSharper disable once Xaml.InvalidType  -->
        <Grid
            Grid.Row="1"
            IsVisible="{Binding NoResultsFound}">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="24"
                FontWeight="Bold">
                No Results Found
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>