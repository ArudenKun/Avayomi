<!--  ReSharper disable once Xaml.InvalidType  -->
<PleasantWindow
    x:Class="Avayomi.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avayomi="https://github.com/arudenkun/avayomi"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Avayomi"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="avayomi:MainWindowViewModel"
    ExtendsContentIntoTitleBar="True"
    Icon="/Assets/logo.ico"
    TitleBarType="ClassicExtended"
    WindowStartupLocation="CenterScreen"
    WindowState="{Binding AppearanceSettings.LastWindowState,
                          Mode=TwoWay}"
    mc:Ignorable="d">
    <ContentControl Content="{Binding ShellViewModel}" />
</PleasantWindow>