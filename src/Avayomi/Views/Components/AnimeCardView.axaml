<UserControl
    x:Class="Avayomi.Views.Components.AnimeCardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
    xmlns:avayomi="https://github.com/arudenkun/avayomi"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="avayomi:AnimeCardViewModel"
    mc:Ignorable="d">
    <!--  ReSharper disable once Xaml.InvalidType  -->
    <avayomi:BusyArea
        Background="Transparent"
        Cursor="Hand"
        IsBusy="{Binding IsCoverLoading}">
        <StackPanel
            Width="160"
            Spacing="8">
            <Border
                x:Name="ImageContainer"
                Background="#1E1E1E"
                ClipToBounds="True"
                CornerRadius="8">
                <Grid
                    Width="160"
                    Height="225"
                    ColumnDefinitions="100,60">
                    <!--  ReSharper disable Xaml.InvalidType  -->
                    <Image
                        x:Name="AnimeImage"
                        Grid.ColumnSpan="2"
                        asyncImageLoader:ImageLoader.IsLoading="{Binding IsCoverLoading,
                                                                         Mode=OneWayToSource}"
                        asyncImageLoader:ImageLoader.Source="{Binding CoverUrl,
                                                                      Mode=OneWay}"
                        Stretch="UniformToFill"
                        ToolTip.Tip="Click to show details" />
                    <!--  ReSharper restore Xaml.InvalidType  -->
                    <!--  ReSharper disable once Xaml.InvalidType  -->
                    <Border
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Background="Transparent">
                        <avayomi:FloatingActionButton AutoClose="False">
                            <avayomi:FloatingActionButton.TriggerContent>
                                <PathIcon Data="{x:Static MaterialIcons.Plus}" />
                            </avayomi:FloatingActionButton.TriggerContent>
                            <Button Background="{DynamicResource BackgroundColor1}">
                                <PathIcon Data="{x:Static MaterialIcons.CalendarPlus}" />
                            </Button>
                            <Button Background="{DynamicResource BackgroundColor1}">
                                <PathIcon Data="{x:Static MaterialIcons.Play}" />
                            </Button>
                            <Button Background="{DynamicResource BackgroundColor1}">
                                <PathIcon Data="{x:Static MaterialIcons.Check}" />
                            </Button>
                            <Button Background="{DynamicResource BackgroundColor1}">
                                <PathIcon Data="{x:Static MaterialIcons.TrashCan}" />
                            </Button>
                        </avayomi:FloatingActionButton>
                    </Border>
                </Grid>
            </Border>
            <!--  ReSharper disable once Xaml.InvalidType  -->
            <TextBlock
                x:Name="AnimeTitle"
                MaxHeight="60"
                FontSize="13"
                FontWeight="Medium"
                Text="{Binding Title}"
                TextAlignment="Center"
                TextTrimming="CharacterEllipsis"
                TextWrapping="Wrap"
                ToolTip.Tip="{Binding #AnimeTitle.Text}" />
        </StackPanel>
    </avayomi:BusyArea>
</UserControl>